# Telegram bot token used by the notifier (referenced as $TELEGRAM_BOT_TOKEN
# inside data/config/settings.yaml). Leave commented if you don't use Telegram.
# TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Services bind to localhost by default. Set the matching *_BIND value to
# 0.0.0.0 only when exposing the service on a trusted LAN.
# JOB_SEARCH_DASHBOARD_BIND=127.0.0.1
# JOB_SEARCH_API_BIND=127.0.0.1
# JOB_SEARCH_MCP_BIND=127.0.0.1

# Optional bearer token for the REST API. When set, requests must include:
# Authorization: Bearer <token>
# JOB_SEARCH_API_TOKEN=

# Override the dashboard port if 8501 is busy.
# JOB_SEARCH_DASHBOARD_PORT=8501

# Override the API port if 8502 is busy (requires --profile api).
# JOB_SEARCH_API_PORT=8502

# Override the MCP port if 3001 is busy (requires --profile mcp).
# JOB_SEARCH_MCP_PORT=3001
