# Docker images to pull in docker-compose.yml (two variants)
#   - Core (slim, no Streamlit) — used by jobsearch / scheduler / analyze / init-config
#   - Dashboard (full, with Streamlit) — used by the dashboard service
JOB_SEARCH_CORE_IMAGE=vincenzoimp/job-search-tool:latest-core
JOB_SEARCH_DASHBOARD_IMAGE=vincenzoimp/job-search-tool:latest

# Linux users can export their local IDs before `docker compose up`
# JOB_SEARCH_UID=$(id -u)
# JOB_SEARCH_GID=$(id -g)
JOB_SEARCH_UID=1000
JOB_SEARCH_GID=1000

# Optional dashboard port override
JOB_SEARCH_DASHBOARD_PORT=8501

# Telegram Bot Token (required only if notifications are enabled)
TELEGRAM_BOT_TOKEN=your_bot_token_here
