# Telegram bot token used by the notifier (referenced as $TELEGRAM_BOT_TOKEN
# inside data/config/settings.yaml). Leave commented if you don't use Telegram.
# TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# The unified web server binds to localhost by default. Use 0.0.0.0 only on a
# trusted LAN and keep firewall rules tight.
# JOB_SEARCH_WEB_BIND=127.0.0.1

# Override the web port if 8501 is busy.
# JOB_SEARCH_WEB_PORT=8501

# Optional bearer token for REST API routes under /api. When set, requests must
# include: Authorization: Bearer <token>
# JOB_SEARCH_API_TOKEN=

# MCP DNS rebinding protection allows localhost by default. Add LAN hostnames or
# IPs only when connecting to /mcp from another trusted device.
# JOB_SEARCH_WEB_ALLOWED_HOSTS=192.168.1.10:8501
# JOB_SEARCH_WEB_ALLOWED_ORIGINS=http://192.168.1.10:8501
