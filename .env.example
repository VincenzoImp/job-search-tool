# Telegram bot token used by the notifier (referenced as $TELEGRAM_BOT_TOKEN
# inside data/config/settings.yaml). Leave commented if you don't use Telegram.
# TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Linux: run containers as your host user so files under ./data stay owned by you.
# JOB_SEARCH_UID=1000
# JOB_SEARCH_GID=1000

# Override the dashboard port if 8501 is busy.
# JOB_SEARCH_DASHBOARD_PORT=8501

# Override the API port if 8502 is busy (requires --profile api).
# JOB_SEARCH_API_PORT=8502

# Override the MCP port if 3001 is busy (requires --profile mcp).
# JOB_SEARCH_MCP_PORT=3001
